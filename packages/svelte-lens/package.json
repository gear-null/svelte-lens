{
  "name": "@gear-null/svelte-lens",
  "version": "1.0.0",
  "description": "Hover any UI element in your browser, copy its source context for AI agents. Built for Svelte 5. Includes CLI and MCP server.",
  "keywords": [
    "svelte",
    "agent",
    "context",
    "lens",
    "grab",
    "devtools",
    "mcp",
    "cli"
  ],
  "license": "MIT",
  "author": "gear-null",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gear-null/svelte-lens.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "svelte-lens": "./bin/cli.js",
    "svelte-lens-mcp": "./bin/mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.svelte.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build && tsup",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:package": "vitest run --config vitest.package.config.ts",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig tsconfig.json && tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.0",
    "element-source": "^0.0.5",
    "package-manager-detector": "^1.0.0",
    "picocolors": "^1.1.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "homepage": "https://github.com/gear-null/svelte-lens#readme",
  "bugs": {
    "url": "https://github.com/gear-null/svelte-lens/issues"
  }
}
