{
  "name": "sv-lens",
  "version": "0.0.0",
  "description": "Short alias for svelte-lens. Hover any Svelte UI element, copy source context for AI agents.",
  "keywords": [
    "svelte",
    "agent",
    "lens",
    "grab"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "svelte-lens": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
