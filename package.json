{
  "name": "svelte-lens-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@gear-null/svelte-lens --filter=@svelte-lens/e2e-app",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,js,svelte,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,svelte,json,md}\"",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "turbo": "^2.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
